
NODE_1_NETWORK=testnet
NODE_1_AUTO_REGISTER=true
NODE_1_AUTO_UNREGISTER=true
NODE_1_REGISTER_MODE=prod
NODE_1_ORACLE_HTTP_INSECURE_TLS=true
NODE_1_DELEGATED_CONTROLLER_CAP_ID=<YOUR NODE DELEGATED CONTROLLERCAP>

# Network-specific oracle config.
DEVNET_IOTA_RPC_URL=https://api.devnet.iota.cafe
DEVNET_ORACLE_TASKS_PACKAGE_ID=0x5187b9f144e2ecd90e42276d00480015648c16d6eb7c4a8083895a4801b22a87
DEVNET_ORACLE_SYSTEM_PACKAGE_ID=0x86f4f7c1bd5852a9765432709ea0dea59a76c7c1d8706d13b2240144f4b7ddec
DEVNET_ORACLE_STATE_ID=0x695c636b5b54cbabefbd401d2f81cbccffd802c3764d4770463f4ab52db07e37
DEVNET_ORACLE_TREASURY_ID=0x5f257ad2c506c7efc3c68ed22f0d709fc5b649453f66205e2e655deb2cb7f8a4
DEVNET_CONTROLLER_CAP_ID=0x80dcb57cd67f95e161c96fb873f98ad41eb120b0154c257ed5139f5507c91058
DEVNET_ORACLE_NODE_REGISTRY_ID=0x57e0f106ffff64fc5d9fc5bc955b07fd4eea36ad923585441fb2e4e43634c2bf
DEVNET_ORACLE_TASK_SCHEDULER_QUEUE_ID=0x2cd20e6c3b3d7bfc2ea96cdbe8296e581c90042196b23a76ffdfad0dd09cc355
DEVNET_ORACLE_TASK_REGISTRY_ID=0xc1aec8fa3a4de5a46c5cfe279f669ba539ef8f6eba3fa1e16ee1819d2b43b43c

TESTNET_IOTA_RPC_URL=https://api.testnet.iota.cafe
TESTNET_ORACLE_VALIDATOR_CAPS_PACKAGE_ID=0xa20f8117eccd5d003991d3fe9fa2a440841a74d96017e3e6af0024b524d9c09b
TESTNET_ORACLE_TASKS_PACKAGE_ID=0x4586bab7b07a8dbeeb43770a7974bfcbb885f2e6985439cac1f28ecf58332892
TESTNET_ORACLE_SYSTEM_PACKAGE_ID=0x24360e39643f72e1edb197aa37ce37ec667775f9e85f35a01a94d8fb9f6b8357
TESTNET_ORACLE_STATE_ID=0x75433fd0d878a1bf14607894d9c7305e63976e2711ee9ffd0f04b0dc0924d5a7
TESTNET_ORACLE_TREASURY_ID=0x694f815d093e89505196d35bdc2847a14744b1ab69b17d98d368bcb44b791023
TESTNET_CONTROLLER_CAP_ID=0xf7359c3997c0b7118a7df30467dec52d5bd91ec1879d3970d403852e214eec39
TESTNET_ORACLE_NODE_REGISTRY_ID=0x21107c5af0b666483ecd4ec963467fbd82275543f09fb28c176a9abecbbbfb12
TESTNET_ORACLE_TASK_SCHEDULER_QUEUE_ID=0x78ac161d14c90f392e45095f6e7640f756a193e1c97930e940f96ad4732c6718
TESTNET_ORACLE_TASK_REGISTRY_ID=0xe69f7eac8ea3c04028c1665409984acfd5a19064cf70686e83604e9db9f83a1e

MAINNET_IOTA_RPC_URL=https://api.mainnet.iota.cafe
MAINNET_ORACLE_VALIDATOR_CAPS_PACKAGE_ID=
MAINNET_ORACLE_TASKS_PACKAGE_ID=
MAINNET_ORACLE_SYSTEM_PACKAGE_ID=
MAINNET_ORACLE_STATE_ID=
MAINNET_ORACLE_TREASURY_ID=
MAINNET_CONTROLLER_CAP_ID=
MAINNET_ORACLE_NODE_REGISTRY_ID=
MAINNET_ORACLE_TASK_SCHEDULER_QUEUE_ID=
MAINNET_ORACLE_TASK_REGISTRY_ID=

# System objects (defaults are usually correct)
IOTA_SYSTEM_STATE_ID=0x5
IOTA_CLOCK_ID=0x6

# Registration
AUTO_REGISTER=true
AUTO_UNREGISTER=true
REGISTER_MODE=prod
# Non-dev networks are forced to prod registration.
# Node registration uses systemState::register_oracle_node and requires
# a DelegatedControllerCap owned by the signer key.
# Optional: set a network-specific delegated cap id, otherwise auto-discovered from signer address.

# Polling
EVENT_POLL_MS=1200

# Gas
GAS_BUDGET=50000000
GAS_BUDGET_COMMIT_SIG=30000000
GAS_BUDGET_REVEAL=30000000
GAS_BUDGET_PARTIAL_SIG=30000000
GAS_BUDGET_NODE_COMMIT=40000000
GAS_BUDGET_FINALIZE=250000000
GAS_BUDGET_REQUEST_DATA=20000000
GAS_BUDGET_SUBMIT_DATA=30000000
GAS_BUDGET_CLOSE_DATA=20000000

# Consensus policy
LEADER_ONLY_FINALIZE=true
NON_LEADER_FINALIZE_DELAY_MS=15000

# Timing (ms)
WAIT_REVEAL_MS=90000
WAIT_REVEAL_POLL_MS=1500
REVEAL_COLLECT_WAIT_MS=40000
REVEAL_COLLECT_POLL_MS=1500
PARTIAL_COLLECT_WAIT_MS=60000
PARTIAL_COLLECT_POLL_MS=2000
FINALIZE_WAIT_MS=60000
WAIT_MATCHING_NODE_COMMITS_MS=20000
WAIT_MATCHING_NODE_COMMITS_POLL_MS=1200
FINALIZE_POLL_MS=2500

# STORAGE fetch limits (content is persisted on IPFS only)
STORAGE_FETCH_TIMEOUT_MS=30000
STORAGE_MAX_DOWNLOAD_BYTES=25000000


# LLM task execution (OpenAI-compatible Chat Completions endpoint)
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
# Optional fallback models, comma-separated, tried left-to-right when the
# primary model fails with a retryable error (429, 500, 502, 503, timeout).
# Example: if LLM_MODEL=a and LLM_MODEL_FALLBACK=b,c the order is a -> b -> c.
# Leave empty to disable fallback.
# Example: LLM_MODEL_FALLBACK=anthropic/claude-haiku-4-5-20251001,google/gemini-2.5-flash-lite
LLM_MODEL_FALLBACK=
# Optional extra HTTP headers for self-hosted or proxied gateways, as JSON object.
# Example: {"Helicone-Auth":"Bearer ..."}
LLM_API_HEADERS_JSON=
# Optional provider-specific plugins array, as JSON.
# Required for OpenRouter to handle PDF inputs and JSON healing.
# Leave empty when using OpenAI directly.
# Example: [{"id":"file-parser","pdf":{"engine":"native"}},{"id":"response-healing"}]
LLM_PLUGINS_JSON=
LLM_TIMEOUT_MS=60000
LLM_MAX_OUTPUT_TOKENS=400
LLM_MAX_INPUT_CHARS=20000

# PDF fetch/extraction for LLM tasks
LLM_PDF_FETCH_TIMEOUT_MS=30000
LLM_PDF_MAX_DOWNLOAD_BYTES=25000000
LLM_PDFTOTEXT_BIN=pdftotext
LLM_PDFTOTEXT_MAX_BUFFER_BYTES=10000000

# Accepted task templates for this node.
# Use a comma-separated list, for example: 1,2,3,4
# Empty, *, or all resolve to the default vector: 1,2,3,4
# Add your LLM template ids here when enabled, for example: 1,2,3,4,101,102,103
ORACLE_ACCEPTED_TEMPLATE_IDS=

# IPFS publication for STORAGE tasks
IPFS_ENABLED=true
IPFS_API_URL=https://api-ipfs.objectid.io
IPFS_PIN=true
IPFS_CID_VERSION=1
IPFS_BEARER_TOKEN=
IPFS_BASIC_AUTH_USER=oracle_ipfs_user
IPFS_BASIC_AUTH_PASS=METTI_LA_PASSWORD_REALE
IPFS_API_KEY=
IPFS_API_SECRET=
